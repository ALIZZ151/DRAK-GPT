# Firebase public config. Isi di Vercel Environment Variables, jangan commit value asli.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# DRAK-GPT memakai Firebase Anonymous Auth + Firestore REST.
# Aktifkan Anonymous Auth dan pasang firestore.rules dari repo ini.

# Access gate server-side. Ini aman karena TIDAK dikirim ke frontend.
# Isi di Vercel Environment Variables.
DRAK_ACCESS_ENABLED=true
DRAK_ACCESS_KEY=
DRAK_ACCESS_PASSWORD=
# Opsional: isi random panjang supaya token login tetap aman.
DRAK_ACCESS_TOKEN_SECRET=
# 720 jam = 30 hari. Setelah expired user login ulang.
DRAK_ACCESS_TOKEN_TTL_HOURS=720

# Provider AI baru. Isi di Vercel Environment Variables.
WORMGPT_API_URL=https://api.wormgpt.pw/v1/chat/completions
# Key utama:
WORMGPT_API_KEY=
# Key cadangan kalau key utama limit/habis token/error:
WORMGPT_API_KEY_2=
WORMGPT_API_KEY_3=
# Alternatif: bisa pakai satu env berisi banyak key, pisahkan koma atau baris baru.
# WORMGPT_API_KEYS=wgpt_key_pertama,wgpt_key_kedua,wgpt_key_ketiga

# Alternatif nama env lama yang juga masih dibaca backend:
DRAK_PROVIDER_API_KEY=

# Opsional kalau provider mewajibkan model tertentu:
WORMGPT_MODEL=

# Optional: set false kalau tidak mau instruksi format Markdown/code block dikirim ke provider.
DRAK_FORMAT_RESPONSES=true

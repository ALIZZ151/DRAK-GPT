# Firebase public config. Isi di Vercel Environment Variables, jangan hardcode di repo.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Provider AI baru. Isi salah satu saja di Vercel Environment Variables.
# Jangan taruh value asli di frontend / file public.
WORMGPT_API_URL=https://api.wormgpt.pw/v1/chat/completions
WORMGPT_API_KEY=
WORMGPT_API_KEY_2=
WORMGPT_API_KEY_3=

# Alternatif nama env lama yang juga dibaca backend:
DRAK_PROVIDER_API_KEY=

# Opsional kalau provider mewajibkan model tertentu:
WORMGPT_MODEL=

# Login key/password website. Isi value asli hanya di Vercel.
DRAK_ACCESS_KEY=
DRAK_ACCESS_PASSWORD=
DRAK_ACCESS_TOKEN_SECRET=

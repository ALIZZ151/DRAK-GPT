# Firebase public config. Isi di Vercel Environment Variables, jangan commit value asli.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# DRAK-GPT memakai Firebase Anonymous Auth + Firestore REST.
# Aktifkan Anonymous Auth dan pasang firestore.rules dari repo ini.

# Provider AI baru. Isi salah satu saja di Vercel Environment Variables.
# Jangan taruh value asli di frontend / file publik.
WORMGPT_API_URL=https://api.wormgpt.pw/v1/chat/completions
WORMGPT_API_KEY=
# Alternatif nama env lama yang juga dibaca backend:
DRAK_PROVIDER_API_KEY=
# Opsional kalau provider mewajibkan model tertentu:
WORMGPT_MODEL=

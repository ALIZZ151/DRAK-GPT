# Database PostgreSQL serverless, rekomendasi Neon Postgres.
DATABASE_URL=

# Secret server-side. Jangan pakai prefix VITE_.
SESSION_SECRET=
API_KEY_ENCRYPTION_SECRET=

# Seed super admin pertama.
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# Fallback opsional jika belum ada API key di database.
AI_DEFAULT_API_URL=
AI_DEFAULT_API_KEY=
AI_DEFAULT_MODEL=

NODE_ENV=production
APP_BASE_URL=https://alizz.my.id
